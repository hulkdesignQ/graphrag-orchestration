---
import type { Lang } from "@/i18n/languages";
import { useTranslations } from "@/i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const primary = [
  { badge: t("useCases.legal.badge"), q: t("useCases.legal.question"), a: t("useCases.legal.answer") },
  { badge: t("useCases.finance.badge"), q: t("useCases.finance.question"), a: t("useCases.finance.answer") },
  { badge: t("useCases.compliance.badge"), q: t("useCases.compliance.question"), a: t("useCases.compliance.answer") },
];

const more = [
  { badge: t("useCases.research.badge"), q: t("useCases.research.question"), a: t("useCases.research.answer") },
  { badge: t("useCases.realestate.badge"), q: t("useCases.realestate.question"), a: t("useCases.realestate.answer") },
  { badge: t("useCases.personal.badge"), q: t("useCases.personal.question"), a: t("useCases.personal.answer") },
];
---

<section id="use-cases" class="py-20 md:py-32 bg-apple-bg">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-5xl text-apple-text tracking-tight">{t("useCases.headline")}</h2>
      <p class="mt-5 text-lg text-apple-secondary">{t("useCases.subheadline")}</p>
    </div>

    <div class="mt-16 grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {primary.map((uc) => (
        <div class="bg-white p-8 rounded-2xl">
          <span class="text-xs font-medium text-apple-blue border border-apple-blue/30 px-3 py-1 rounded-full">{uc.badge}</span>
          <h3 class="mt-4 text-lg font-semibold text-apple-text">{uc.q}</h3>
          <p class="mt-3 text-[15px] text-apple-secondary leading-relaxed" set:html={uc.a} />
        </div>
      ))}
    </div>

    <div id="more-use-cases" class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-5xl mx-auto hidden">
      {more.map((uc) => (
        <div class="bg-white p-8 rounded-2xl">
          <span class="text-xs font-medium text-apple-blue border border-apple-blue/30 px-3 py-1 rounded-full">{uc.badge}</span>
          <h3 class="mt-4 text-lg font-semibold text-apple-text">{uc.q}</h3>
          <p class="mt-3 text-[15px] text-apple-secondary leading-relaxed" set:html={uc.a} />
        </div>
      ))}
    </div>

    <div class="text-center mt-10 flex justify-center gap-6">
      <button
        id="toggle-use-cases"
        class="text-apple-blue text-sm hover:underline"
        data-more={t("useCases.moreBtn")}
        data-less={t("useCases.lessBtn")}
      >
        {t("useCases.moreBtn")}
      </button>
      <a href="/use-cases" class="text-apple-blue text-sm hover:underline">View detailed use cases ›</a>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("toggle-use-cases");
  const panel = document.getElementById("more-use-cases");
  btn?.addEventListener("click", () => {
    const isHidden = panel?.classList.toggle("hidden");
    btn.textContent = isHidden ? btn.dataset.more! : btn.dataset.less!;
  });
</script>
