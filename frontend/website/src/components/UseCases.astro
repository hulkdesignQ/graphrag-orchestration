---
import type { Lang } from "@/i18n/languages";
import { useTranslations, getLocalePath } from "@/i18n/utils";

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { slug: "legal", badge: t("useCases.legal.badge"), q: t("useCases.legal.question") },
  { slug: "finance", badge: t("useCases.finance.badge"), q: t("useCases.finance.question") },
  { slug: "compliance", badge: t("useCases.compliance.badge"), q: t("useCases.compliance.question") },
  { slug: "research", badge: t("useCases.research.badge"), q: t("useCases.research.question") },
  { slug: "real-estate", badge: t("useCases.realestate.badge"), q: t("useCases.realestate.question") },
  { slug: "personal", badge: t("useCases.personal.badge"), q: t("useCases.personal.question") },
];
---

<section id="use-cases" class="py-20 md:py-32 bg-apple-bg">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-5xl text-apple-text tracking-tight">{t("useCases.headline")}</h2>
      <p class="mt-5 text-lg text-apple-secondary">{t("useCases.subheadline")}</p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {items.map((uc) => (
        <a href={getLocalePath(lang, `/use-cases/${uc.slug}`)} class="bg-white p-8 rounded-2xl hover:shadow-lg transition-shadow group block">
          <span class="text-xs font-medium text-apple-blue border border-apple-blue/30 px-3 py-1 rounded-full">{uc.badge}</span>
          <h3 class="mt-4 text-lg font-semibold text-apple-text group-hover:text-apple-blue transition-colors">{uc.q}</h3>
          <span class="mt-3 inline-block text-sm text-apple-blue">Learn more ›</span>
        </a>
      ))}
    </div>
  </div>
</section>

