---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { useCases, useCaseOrder } from "@/content/use-cases";

const lang = "en";
---

<Layout title="Use Cases — Evidoc" lang={lang}>
  <Nav lang={lang} />

  <section class="pt-28 pb-16 md:pt-40 md:pb-24 bg-white">
    <div class="container mx-auto px-6 text-center max-w-3xl">
      <h1 class="text-4xl md:text-6xl text-apple-text leading-[1.08] tracking-tight">
        Built for how you work.
      </h1>
      <p class="mt-6 text-xl text-apple-secondary max-w-2xl mx-auto leading-relaxed">
        See how teams across industries use Evidoc to get answers from their documents — with proof.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-apple-bg">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {useCaseOrder.map((key) => {
          const uc = useCases[key];
          return (
            <a href={`/use-cases/${uc.slug}`} class="bg-white p-8 rounded-2xl hover:shadow-lg transition-shadow group">
              <span class="text-xs font-medium text-apple-blue border border-apple-blue/30 px-3 py-1 rounded-full">
                {uc.badge}
              </span>
              <h2 class="mt-4 text-lg font-semibold text-apple-text group-hover:text-apple-blue transition-colors" set:html={uc.heroTitle.replace('<br>', ' ')} />
              <p class="mt-3 text-[15px] text-apple-secondary leading-relaxed line-clamp-3">
                {uc.heroSubtitle}
              </p>
              <span class="mt-4 inline-block text-sm text-apple-blue">
                Learn more ›
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>
